# ==========================================
# .NET / Visual Studio
# ==========================================
bin/
obj/
[Bb]in/
[Oo]bj/
*.user
*.userosscache
*.sln.docstates
.vs/
.vscode/
# Keep .vscode/settings.json if you want shared settings, but ignore the rest:
.vscode/*
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json
# !.vscode/extensions.json

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because they are restored on build
**/packages/*
!**/packages/build/

# ==========================================
# Angular / Node.js
# ==========================================
# Dependency directories
node_modules/
**/node_modules/

# Angular build output
dist/
**/dist/
.angular/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# TypeScript cache
*.tsbuildinfo

# ==========================================
# Operating System Files
# ==========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# ==========================================
# Environment Secrets
# ==========================================
.env
.env.test
.env.production
appsettings.Development.json
# Note: Usually, you keep appsettings.json in git, 
# but keep specific secrets in user-secrets or environment variables.